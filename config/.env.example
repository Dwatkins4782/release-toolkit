# =============================================================================
# Release Toolkit — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# These override settings in release-config.yaml.

# --- Git / SCM ---
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Jira ---
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JIRA_USER_EMAIL=devops@myorg.com
JIRA_BASE_URL=https://myorg.atlassian.net

# --- Docker Registries ---
DOCKER_REGISTRY_DEV=registry.dev.myorg.com
DOCKER_REGISTRY_STAGING=registry.staging.myorg.com
DOCKER_REGISTRY_PROD=registry.prod.myorg.com

# --- Kubernetes ---
KUBECONFIG_QA=/path/to/qa-kubeconfig
KUBECONFIG_STAGING=/path/to/staging-kubeconfig
KUBECONFIG_PROD=/path/to/prod-kubeconfig

# --- Notifications ---
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxxxxxxx

# --- Harness CD ---
HARNESS_API_KEY=pat.xxxxxxxxxxxxxxxxxxxx
HARNESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Monitoring ---
DYNATRACE_API_TOKEN=dt0c01.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GRAFANA_API_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Feature Toggles ---
FEATURE_TOGGLE_API_KEY=api-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- QA Automation ---
QA_AUTOMATION_API_KEY=qa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
